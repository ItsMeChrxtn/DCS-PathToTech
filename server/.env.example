# ===== ENVIRONMENT =====
NODE_ENV=development
# For production: NODE_ENV=production

# ===== SERVER =====
PORT=5000
# Render auto-assigns PORT, but keep this as fallback

# ===== DATABASE =====
# Local Development
MONGODB_URI=mongodb+srv://PathTotech:PathTotech_2026@pathtotechdatabase.csiubwm.mongodb.net/?appName=PathToTechDatabase
# Production (MongoDB Atlas)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/pathtotech?retryWrites=true&w=majority

# ===== AUTHENTICATION =====
JWT_SECRET=pathtotech_super_secret_2026_secure_key
