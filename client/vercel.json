{
  "buildCommand": "CI=false npm run build",
  "outputDirectory": "build",
  "env": {
    "REACT_APP_API_URL": "https://dcs-pathtotech-2.onrender.com/api"
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
